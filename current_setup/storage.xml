<clickhouse>
    <storage_configuration>
        <disks>
            <local_d1>
                <path>/var/lib/clickhouse-disks/d1/local_data/</path>
                <keep_free_space_bytes>107374182400</keep_free_space_bytes>
            </local_d1>
            <local_d2>
                <path>/var/lib/clickhouse-disks/d2/local_data/</path>
                <keep_free_space_bytes>107374182400</keep_free_space_bytes>
            </local_d2>
            <ovh_bucket>
                <type>s3</type>
                <endpoint>https://clickhouse-web-observations-storage-backend-v2.s3.us-east-va.io.cloud.ovh.us/</endpoint>
                <access_key_id>db4b3913a6384fc3956f41b047cecd25</access_key_id>
                <secret_access_key>15c3a5fc23254bc38eecd9679d22edc4</secret_access_key>
                <send_metadata>false</send_metadata>
                <s3_strict_upload_part_size>16777216</s3_strict_upload_part_size>
            </ovh_bucket>
            <ovh_cache>
                <type>cache</type>
                <disk>ovh_bucket</disk>
                <path>/var/lib/clickhouse-disks/d1/s3_cache/</path>
                <max_size>3000Gi</max_size>
                <cache_on_write_operations>1</cache_on_write_operations>
            </ovh_cache>
        </disks>
        <policies>
            <jbod>
                <volumes>
                    <data>
                        <disk>local_d1</disk>
                        <disk>local_d2</disk>
                        <load_balancing>round_robin</load_balancing>
                    </data>
                </volumes>
            </jbod>
            <ovh_main>
                <volumes>
                    <main>
                        <disk>ovh_cache</disk>
                    </main>
                </volumes>
            </ovh_main>
        </policies>
    </storage_configuration>
</clickhouse>